{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HukuKaich0u/agent-kit/plugins/deep-research/schemas/scope.schema.json",
  "title": "ScopeResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "question",
    "summary",
    "assumptions",
    "temporalScope",
    "geographicScope",
    "searchLanguages",
    "reportLanguage",
    "decisionCriteria",
    "ambiguities",
    "excludedAreas",
    "expectedSourceTypes",
    "angles"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "question": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "assumptions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "temporalScope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asOf", "dateFrom", "dateTo", "rationale"],
      "properties": {
        "asOf": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "dateFrom": { "type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "dateTo": { "type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
        "rationale": { "type": "string", "minLength": 1 }
      }
    },
    "geographicScope": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "searchLanguages": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 2 }
    },
    "reportLanguage": { "type": "string", "minLength": 2 },
    "decisionCriteria": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "ambiguities": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "excludedAreas": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "expectedSourceTypes": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceType" }
    },
    "angles": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "rationale", "queries", "preferredSourceTypes"],
        "properties": {
          "id": { "type": "string", "pattern": "^A[0-9]{2,}$" },
          "label": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "queries": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "preferredSourceTypes": {
            "type": "array",
            "items": { "$ref": "#/$defs/sourceType" }
          }
        }
      }
    }
  },
  "$defs": {
    "sourceType": {
      "type": "string",
      "enum": [
        "primary_research",
        "official_document",
        "official_statistics",
        "first_party_statement",
        "secondary_reporting",
        "systematic_review",
        "expert_analysis",
        "advocacy",
        "commercial_content",
        "community",
        "unknown"
      ]
    }
  }
}
