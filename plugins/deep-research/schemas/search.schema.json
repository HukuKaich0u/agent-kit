{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HukuKaich0u/agent-kit/plugins/deep-research/schemas/search.schema.json",
  "title": "SearchResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "angleId", "results"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "angleId": { "type": "string", "pattern": "^A[0-9]{2,}$" },
    "results": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "url",
          "title",
          "publisher",
          "hostname",
          "publisherGroup",
          "snippet",
          "publishedAt",
          "sourceType",
          "relevance",
          "relevanceRationale",
          "query"
        ],
        "properties": {
          "url": { "type": "string", "pattern": "^https?://" },
          "title": { "type": "string", "minLength": 1 },
          "publisher": { "type": ["string", "null"], "minLength": 1 },
          "hostname": { "type": "string", "minLength": 1 },
          "publisherGroup": { "type": ["string", "null"], "minLength": 1 },
          "snippet": { "type": "string", "minLength": 1 },
          "publishedAt": { "type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "sourceType": { "$ref": "#/$defs/sourceType" },
          "relevance": { "type": "string", "enum": ["high", "medium", "low"] },
          "relevanceRationale": { "type": "string", "minLength": 1 },
          "query": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "sourceType": {
      "type": "string",
      "enum": [
        "primary_research",
        "official_document",
        "official_statistics",
        "first_party_statement",
        "secondary_reporting",
        "systematic_review",
        "expert_analysis",
        "advocacy",
        "commercial_content",
        "community",
        "unknown"
      ]
    }
  }
}
