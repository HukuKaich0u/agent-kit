{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HukuKaich0u/agent-kit/plugins/deep-research/schemas/challenge.schema.json",
  "title": "ChallengeResult",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "claimId", "status", "rationale", "counterSources", "queriesUsed"],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "claimId": { "type": "string", "pattern": "^C[0-9]{3,}$" },
    "status": {
      "type": "string",
      "enum": ["contradicted", "materially_qualified", "no_counterevidence_found", "search_failed"]
    },
    "rationale": { "type": "string", "minLength": 1 },
    "counterSources": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "url",
          "title",
          "publisher",
          "publishedAt",
          "sourceType",
          "quality",
          "relationship",
          "evidenceExcerpt",
          "locator"
        ],
        "properties": {
          "url": { "type": "string", "pattern": "^https?://" },
          "title": { "type": "string", "minLength": 1 },
          "publisher": { "type": ["string", "null"], "minLength": 1 },
          "publishedAt": { "type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
          "sourceType": { "$ref": "#/$defs/sourceType" },
          "quality": { "type": "string", "enum": ["high", "medium", "low", "unknown"] },
          "relationship": {
            "type": "string",
            "enum": ["contradicts", "qualifies", "updates", "methodology_critique"]
          },
          "evidenceExcerpt": { "type": "string", "minLength": 1 },
          "locator": { "type": ["string", "null"], "minLength": 1 }
        }
      }
    },
    "queriesUsed": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  },
  "$defs": {
    "sourceType": {
      "type": "string",
      "enum": [
        "primary_research",
        "official_document",
        "official_statistics",
        "first_party_statement",
        "secondary_reporting",
        "systematic_review",
        "expert_analysis",
        "advocacy",
        "commercial_content",
        "community",
        "unknown"
      ]
    }
  }
}
