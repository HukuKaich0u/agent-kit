{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HukuKaich0u/agent-kit/plugins/deep-research/schemas/report.schema.json",
  "title": "ReportResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "title",
    "asOf",
    "scope",
    "executiveSummary",
    "findings",
    "disagreements",
    "limitations",
    "openQuestions",
    "methodology"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "1.0" },
    "title": { "type": "string", "minLength": 1 },
    "asOf": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" },
    "scope": { "type": "string", "minLength": 1 },
    "executiveSummary": { "type": "string", "minLength": 1 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "heading",
          "claim",
          "explanation",
          "confidence",
          "verificationState",
          "sourceIds",
          "claimIds"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^F[0-9]{2,}$" },
          "heading": { "type": "string", "minLength": 1 },
          "claim": { "type": "string", "minLength": 1 },
          "explanation": { "type": "string", "minLength": 1 },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "verificationState": {
            "type": "string",
            "enum": ["confirmed", "qualified", "contested", "refuted", "insufficient", "not_checked"]
          },
          "sourceIds": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^S[0-9]{3,}$" }
          },
          "claimIds": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "pattern": "^C[0-9]{3,}$" }
          }
        }
      }
    },
    "disagreements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["topic", "positions", "unresolvedReason"],
        "properties": {
          "topic": { "type": "string", "minLength": 1 },
          "positions": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["position", "sourceIds"],
              "properties": {
                "position": { "type": "string", "minLength": 1 },
                "sourceIds": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string", "pattern": "^S[0-9]{3,}$" }
                }
              }
            }
          },
          "unresolvedReason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "limitations": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "openQuestions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "methodology": { "type": "string", "minLength": 1 }
  }
}
